
-- CREATION OF TABLES FOR THE AIRBNB DATASET

-- 1. Creating Country table
CREATE TABLE Country (
    Country_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Name VARCHAR(50) NOT NULL,
    Code VARCHAR(15) NOT NULL
);

-- 2. Creating City table
CREATE TABLE City (
    City_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Name VARCHAR(50) NOT NULL,
    Country_ID INT NOT NULL, -- Foreign key referencing Country
    FOREIGN KEY (Country_ID) REFERENCES Country(Country_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 3. Creating Address table
CREATE TABLE Address (
    Address_ID INT AUTO_INCREMENT PRIMARY KEY,
    House_number INT NOT NULL,
    Street_Name VARCHAR(50) NOT NULL,
    Postal_code VARCHAR(15) NOT NULL,
    Property_ID INT,
    City_ID INT,
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (City_ID) REFERENCES City(City_ID) ON DELETE CASCADE ON UPDATE CASCADE
);



-- 4. Creating Users table
CREATE TABLE Users (
    User_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    First_name VARCHAR(50) NOT NULL,
    Last_name VARCHAR(50) NOT NULL,
    Email VARCHAR(50) UNIQUE NOT NULL,
    Phone_number INT NOT NULL
);


-- 5. Creating Property table
CREATE TABLE Property (
    Property_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Property_name VARCHAR(50) NOT NULL,
    Price_per_night DECIMAL(10,2) NOT NULL,
    Availability_status VARCHAR(15) NOT NULL,
    Created_at DATE NOT NULL,
    User_ID INT, -- Foreign key referencing User
    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 6. Creating Booking table
CREATE TABLE Booking (
    Booking_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Check_in_date DATE NOT NULL,
    Check_out_date DATE NOT NULL,
    Total_price DECIMAL(10,2) NOT NULL,
    State VARCHAR(15) NOT NULL,
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    User_ID INT NOT NULL, -- Foreign key referencing User
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 7. Creating Payment table
CREATE TABLE Payment (
    Payment_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Amount DECIMAL(10,2) NOT NULL,
    Payment_method VARCHAR(10) NOT NULL,
    Payment_date DATE NOT NULL,
    Booking_ID INT NOT NULL, -- Foreign key referencing Booking
    User_ID INT NOT NULL, -- Foreign key referencing User
    FOREIGN KEY (Booking_ID) REFERENCES Booking(Booking_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 8. Creating Booking_Cancellation table
CREATE TABLE Booking_Cancellation (
    Booking_can_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Refund_amount DECIMAL(10,2) NOT NULL,
    Cancellation_date DATE NOT NULL,
    Booking_ID INT NOT NULL, -- Foreign key referencing Booking
    FOREIGN KEY (Booking_ID) REFERENCES Booking(Booking_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 9. Creating Property_Review table
CREATE TABLE Property_Review (
    Property_Review_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Review_ID INT NOT NULL, -- Foreign key referencing Review
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    FOREIGN KEY (Review_ID) REFERENCES Review(Review_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 10. Creating Review table
CREATE TABLE Review (
    Review_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Rating DECIMAL(2,1) NOT NULL,
    Comments TEXT NOT NULL,
    Created_at DATE NOT NULL,
    User_ID INT NOT NULL, -- Foreign key referencing User
    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 11. Creating House_Rules table
CREATE TABLE House_Rules (
    Rule_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Descriptions TEXT NOT NULL,
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE
);


-- 12. Creating Promotion table
CREATE TABLE Promotion (
    Promotion_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Promo_code VARCHAR(20) NOT NULL,
    Discount_amount DECIMAL(10,2) NOT NULL,
    Expiry_date DATE NOT NULL,
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 13. Creating Property_Amenity table
CREATE TABLE Property_Amenity (
    Property_Amenity_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    Amenity_ID INT NOT NULL, -- Foreign key referencing Amenity
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (Amenity_ID) REFERENCES Amenity(Amenity_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 14. Creating Amenity table
CREATE TABLE Amenity (
    Amenity_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Amenity_name VARCHAR(50) NOT NULL
);


-- 15. Creating Property_Image table
CREATE TABLE Property_Image (
    Image_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Image_url VARCHAR(300) NOT NULL,
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 16. Creating Guest_Identity table
CREATE TABLE Guest_Identity (
    Identity_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    ID_type VARCHAR(15) NOT NULL,
    ID_number INT NOT NULL,
    ID_photo_URL VARCHAR(300) NOT NULL,
    Selfie_URL VARCHAR(300) NOT NULL,
    Verification_status VARCHAR(15) NOT NULL,
    Submitted_at DATE NOT NULL,
    User_ID INT NOT NULL, -- Foreign key referencing User
    Language_ID INT NOT NULL, -- Foreign key referencing Language

    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (Language_ID) REFERENCES Language (Language_ID) ON DELETE CASCADE   ON UPDATE CASCADE
);

-- 17. Creating Host_Identity table
CREATE TABLE Host_Identity (
    Host_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Document_Type VARCHAR(20) NOT NULL,
    Document_URL VARCHAR(100) NOT NULL,
    User_ID INT NOT NULL, -- Foreign key referencing User
    FOREIGN KEY (User_ID) REFERENCES Users(User_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

-- 18. Creating Host_Earnings table
CREATE TABLE Host_Earnings (
    Earnings_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Amount DECIMAL(10,2) NOT NULL,
    Payout_method VARCHAR(10) NOT NULL,
    Host_ID INT NOT NULL, -- Foreign key referencing User
    FOREIGN KEY (Host_ID) REFERENCES Host_Identity(Host_ID) ON DELETE CASCADE ON UPDATE CASCADE
);


-- 19. Creating Language table
CREATE TABLE Language (
    Language_ID INT AUTO_INCREMENT PRIMARY KEY, -- Unique ID for each language
    Lang VARCHAR(50) NOT NULL UNIQUE -- Ensures no duplicate language entries
);



-- 20. Creating Discount table
CREATE TABLE Discount (
    Percentage_ID INT AUTO_INCREMENT PRIMARY KEY, -- Primary Key
    Start_date DATE NOT NULL,
    End_date DATE NOT NULL,
	Percentage INT NOT NULL, 
    Property_ID INT NOT NULL, -- Foreign key referencing Property
    FOREIGN KEY (Property_ID) REFERENCES Property(Property_ID) ON DELETE CASCADE ON UPDATE CASCADE
);

